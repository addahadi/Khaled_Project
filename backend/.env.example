PORT=3001

# Supabase PostgreSQL direct connection string
# Found in: Supabase Dashboard → Settings → Database → Connection String (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=generate_a_random_48_char_hex_string_here
JWT_REFRESH_SECRET=generate_a_different_48_char_hex_string_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL for CORS and invitation email links
CLIENT_URL=http://localhost:5173

NODE_ENV=development

# Optional: plug in your Python/FastAPI ML service
# If not set, a deterministic mock predictor is used automatically
# AI_SERVICE_URL=http://localhost:8000

# Optional: Resend API key for real invitation emails
# If not set, invitation links are printed to console (fine for development)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# FROM_EMAIL=DiagInfect <no-reply@yourdomain.com>
